{
  "name": "uniride",
  "version": "1.0.0",
  "description": "UniRide - University Ride Marketplace",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build": "eas build",
    "lint": "eslint . --ext .ts,.tsx"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.1.1",
    "@hookform/resolvers": "^5.2.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-picker/picker": "^2.11.0",
    "@react-navigation/native": "7.3.3",
    "@react-navigation/native-stack": "7.17.5",
    "@supabase/supabase-js": "2.58.0",
    "expo": "54.0.12",
    "expo-constants": "18.0.9",
    "expo-linear-gradient": "15.0.7",
    "expo-location": "19.0.7",
    "expo-router": "6.0.8",
    "expo-status-bar": "3.0.8",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "7.63.0",
    "react-native": "0.81.4",
    "react-native-gesture-handler": "2.29.0",
    "react-native-maps": "1.20.1",
    "react-native-reanimated": "4.1.1",
    "react-native-screens": "4.16.0",
    "react-native-uuid": "2.0.3",
    "react-native-web": "^0.21.2",
    "react-native-safe-area-context": "5.6.1",
    "zod": "4.1.11",
    "zustand": "5.0.8"
  },
  "devDependencies": {
    "@types/react": "19.1.17",
    "@types/react-native": "0.72.8",
    "babel-plugin-module-resolver": "^5.0.2",
    "eslint": "9.36.0",
    "eslint-config-expo": "10.0.0",
    "typescript": "5.9.3"
  },
  "expo": {
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermissions": "Allow UniRide to access your location for ride tracking"
        }
      ]
    ]
  }
}